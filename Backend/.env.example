# WhatsApp Cloud API (Meta Developers)
WHATSAPP_VERIFY_TOKEN=seu-token-de-verificacao
WHATSAPP_ACCESS_TOKEN=seu-access-token
WHATSAPP_PHONE_NUMBER_ID=id-do-numero-whatsapp

# Google Gemini API (Google AI Studio)
GEMINI_API_KEY=sua-chave-api-gemini

# --- Hotmart (só precisa se for usar webhook de assinatura / EXIGIR_ASSINATURA_HOTMART=1) ---
# HOTMART_HOTTOK: em app.hotmart.com → Ferramentas → Webhook (API) → aba "Autenticação" → copie o Hottok.
# É um segredo que a Hotmart envia no header X-HOTMART-HOTTOK; cola aqui igualzinho. Não é URL.
# Se deixar vazio, o POST /webhook/hotmart aceita sem validar (útil só em teste local).
HOTMART_HOTTOK=

# O WhatsApp e POST /processar só respondem com IA se USUARIO.TP_SITUACAO = ATIVO (webhook Hotmart). Quem não está ativo recebe mensagem com Instagram/checkout.
# (EXIGIR_ASSINATURA_HOTMART era usado para ligar esse filtro; o filtro está sempre ativo.)
EXIGIR_ASSINATURA_HOTMART=1

# LINK_COMPRA_ASSINATURA: página de pagamento Hotmart — obrigatório para quem não tem assinatura (ex.: ao mandar "oi").
LINK_COMPRA_ASSINATURA=https://pay.hotmart.com/SEU_LINK_DE_CHECKOUT

# LINK_INSTAGRAM: opcional; aparece junto na mensagem de "precisa assinar".
LINK_INSTAGRAM=https://www.instagram.com/seu_perfil/
